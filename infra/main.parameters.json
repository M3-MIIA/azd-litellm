{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "litellmContainerAppExists": {
        "value": "${LITELLM_CONTAINER_APP_EXISTS=false}"
      },
      "databaseHost": {
        "value": "${DATABASE_HOST}"
      },
      "databasePort": {
        "value": "${DATABASE_PORT=5432}"
      },
      "databaseName": {
        "value": "${DATABASE_NAME=litellmdb}"
      },
      "databaseUser": {
        "value": "${DATABASE_USER}"
      },
      "databasePassword": {
        "value": "${DATABASE_PASSWORD}"
      },
      "litellm_master_key": {
        "value": "${LITELLM_MASTER_KEY}"
      },
      "litellm_salt_key": {
        "value": "${LITELLM_SALT_KEY}"
      },
      "openai_api_key": {
        "value": "${OPENAI_API_KEY}"
      },
      "anthropic_api_key": {
        "value": "${ANTHROPIC_API_KEY}"
      },
      "azure_ai_foundry_api_key": {
        "value": "${AZURE_AI_FOUNDRY_API_KEY}"
      },
      "azure_ai_foundry_api_base": {
        "value": "${AZURE_AI_FOUNDRY_API_BASE=https://miia-resource.cognitiveservices.azure.com}"
      },
      "groq_api_key": {
        "value": "${GROQ_API_KEY}"
      },
      "customDomainName": {
        "value": "${CUSTOM_DOMAIN_NAME=}"
      },
      "domainValidationMethod": {
        "value": "${DOMAIN_VALIDATION_METHOD=CNAME}"
      }
    }
  }