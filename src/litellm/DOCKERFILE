# https://docs.litellm.ai/docs/proxy/deploy

FROM python:3.12-slim

USER root
WORKDIR /app

# Install system dependencies required by Prisma and Node.js
RUN apt-get update && apt-get install -y \
    libatomic1 \
    && rm -rf /var/lib/apt/lists/*

ENV HOME=/home/litellm
ENV PATH="${HOME}/venv/bin:$PATH"


RUN python -m venv ${HOME}/venv
RUN ${HOME}/venv/bin/pip install --no-cache-dir --upgrade pip

COPY requirements.txt .
RUN --mount=type=cache,target=${HOME}/.cache/pip \
    ${HOME}/venv/bin/pip install -r requirements.txt

# Generate Prisma client from the schema included in the litellm package
RUN ${HOME}/venv/bin/prisma generate --schema ${HOME}/venv/lib/python*/site-packages/litellm/proxy/schema.prisma

COPY config.yaml .
COPY entrypoint.sh .

RUN chmod +x entrypoint.sh

EXPOSE 80/tcp

ENTRYPOINT ["./entrypoint.sh"]
CMD ["--port", "80", "--config", "config.yaml"]